# Frontend (Expo) Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# ⚠ NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────
#
# KEY ROTATION CHECKLIST (run after any suspected key exposure):
#   1. EXPO_PUBLIC_ADMIN_KEY         — generate: openssl rand -base64 32
#   2. EXPO_PUBLIC_STRIPE_KEY        — https://dashboard.stripe.com/apikeys
#   3. EXPO_PUBLIC_SUPABASE_ANON_KEY — https://supabase.com/dashboard → Settings → API
#
# NOTE: All EXPO_PUBLIC_* variables are embedded into the compiled app bundle.
# Only safe-to-expose values (Stripe publishable key, Supabase anon key) belong here.
# ─────────────────────────────────────────────────────────────────────────────

# --- API URL ---
# Your deployed Vercel backend URL. Use localhost for local development.
EXPO_PUBLIC_API_URL=https://cyvhub-api.vercel.app/api

# --- Supabase (for Realtime driver location tracking) ---
# Get from: Supabase Dashboard → Settings → API → Project URL / anon public key
# The anon key is SAFE to expose — it's designed for client-side use.
EXPO_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_anon_public_key_from_supabase_settings_api

# --- Admin Access ---
# SEC-9: Secret key to reveal the Admin login portal.
# Generate a strong random key: openssl rand -base64 32
EXPO_PUBLIC_ADMIN_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# --- Stripe ---
# Get your PUBLISHABLE key from https://dashboard.stripe.com/apikeys
# The publishable key is safe to expose in client code (by design).
EXPO_PUBLIC_STRIPE_KEY=CHANGE_ME_pk_live_or_pk_test_from_stripe_dashboard
