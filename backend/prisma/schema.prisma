generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  // MIGRATION: Now using Supabase PostgreSQL.
  // DATABASE_URL  — use the Supabase "Transaction" pooler URL (port 6543, ?pgbouncer=true)
  // DIRECT_URL    — use the Supabase "Session" direct URL (port 5432) for prisma migrate
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String // "driver" | "customer" | "admin" | "carrier"
  status       String  @default("PENDING") // "ACTIVE" | "INACTIVE" | "SUSPENDED" | "PENDING"
  phone        String?
  avatar       String?

  // Email verification
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?   @unique
  emailVerifyExpiry DateTime?

  // Password reset
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  jobsAsCustomer Job[] @relation("CustomerJobs")
  jobsAsDriver   Job[] @relation("DriverJobs")
  jobsAsCarrier  Job[] @relation("CarrierJobs")
  quoteRequests  QuoteRequest[]

  businessAccountId String?
  businessAccount   BusinessAccount? @relation(fields: [businessAccountId], references: [id])

  carrierProfileId String?         @unique
  carrierProfile   CarrierProfile? @relation(fields: [carrierProfileId], references: [id])

  // Real-time location tracking for drivers
  lastKnownLat Float?
  lastKnownLng Float?

  // Automated dispatch availability — driver must set this to receive offers
  onlineForDispatch Boolean @default(false)

  // Dispatch offers received as a driver/carrier
  dispatchOffers DispatchAttempt[] @relation("DriverOffers")

  // HR & Payroll Additions
  hrRecord        HRRecord?
  timeOffRequests TimeOffRequest[]
  payslips        Payslip[]

  // Compliance documents
  complianceDocs           DriverComplianceDocument[] @relation("DriverDocs")
  complianceReviews        DriverComplianceDocument[] @relation("ReviewedByAdmin")
  carrierComplianceReviews ComplianceDocument[]       @relation("CarrierDocReview")

  // Disputes & Messages
  createdDisputes Dispute[]        @relation("DisputeCreator")
  targetDisputes  Dispute[]        @relation("DisputeTarget")
  disputeMessages DisputeMessage[] @relation("MessageAuthor")

  // Stripe Connect — marketplace payout fields
  stripeAccountId          String? // Connected account ID (acct_xxx)
  stripeOnboardingComplete Boolean @default(false)
}

// ─── Driver Compliance Documents ────────────────────────────────────────────
// Stores uploaded compliance files (licence, insurance, MOT, etc.) per driver.
// Files are hosted in Supabase Storage; fileUrl is a signed/public URL.
model DriverComplianceDocument {
  id       String @id @default(uuid())
  driverId String
  driver   User   @relation("DriverDocs", fields: [driverId], references: [id], onDelete: Cascade)

  documentType String // e.g. "driving_licence" | "motor_insurance" | "mot" | ...
  fileName     String
  fileUrl      String // Supabase Storage public/signed URL
  mimeType     String?
  fileSize     Int?

  issueDate  DateTime?
  expiryDate DateTime?

  // Status: not_submitted | pending_review | verified | rejected | expired
  status String @default("pending_review")

  adminNote       String?
  rejectionReason String?

  verifiedByAdminId String?
  verifiedByAdmin   User?     @relation("ReviewedByAdmin", fields: [verifiedByAdminId], references: [id], onDelete: SetNull)
  verifiedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([status])
}

model Job {
  id        String @id @default(uuid())
  jobNumber String @unique
  status    String // "DRAFT" | "PENDING_DISPATCH" | "ASSIGNED" | "EN_ROUTE_TO_PICKUP" ...
  priority  String // "NORMAL" | "URGENT"

  pickupContactName  String
  pickupContactPhone String
  pickupAddressLine1 String
  pickupCity         String
  pickupPostcode     String
  pickupLatitude     Float
  pickupLongitude    Float
  pickupWindowStart  String
  pickupWindowEnd    String

  dropoffContactName  String
  dropoffContactPhone String
  dropoffAddressLine1 String
  dropoffCity         String
  dropoffPostcode     String
  dropoffLatitude     Float
  dropoffLongitude    Float
  dropoffWindowStart  String
  dropoffWindowEnd    String

  vehicleType         String
  specialInstructions String?
  goodsDescription    String?
  calculatedPrice     Float
  distanceKm          Float?

  // Delivery Unification Fields
  trackingNumber    String?   @unique
  paymentStatus     String?   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  estimatedDelivery DateTime?
  deliveredAt       DateTime?
  autoInvoiceSent   Boolean   @default(false)

  // Multi-Parcel Analytics
  quantity     Int    @default(1)
  basePrice    Float?
  bulkDiscount Float  @default(0)

  // Relationships
  customerId String?
  customer   User?   @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: SetNull)

  assignedDriverId String?
  assignedDriver   User?   @relation("DriverJobs", fields: [assignedDriverId], references: [id], onDelete: SetNull)

  assignedCarrierId String?
  assignedCarrier   User?   @relation("CarrierJobs", fields: [assignedCarrierId], references: [id], onDelete: SetNull)

  businessAccountId String?
  businessAccount   BusinessAccount? @relation(fields: [businessAccountId], references: [id])

  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Epic 2/3: Commercial Engine Quote Linkage
  quoteRequestId String?       @unique
  quoteRequest   QuoteRequest? @relation(fields: [quoteRequestId], references: [id])

  // New Integration Fields
  jobType         String?
  pickupWindow    String?
  deliveryWindow  String?
  paymentIntentId String?

  parcels Parcel[]

  // Proof of Delivery (POD)
  podUrl       String? // URL to delivery photo
  signatureUrl String? // URL to signature image
  receiverName String? // Name of person who accepted delivery

  // Disputes
  disputes Dispute[] @relation("DisputeJob")

  // Internal Notes (JSON array of { text: string, timestamp: Date, author: string })
  notes Json?

  // Automated Dispatch
  trackingUnlocked     Boolean @default(false)  // gates customer live tracking
  dispatchStatus       String  @default("IDLE") // IDLE | SEARCHING | OFFER_SENT | ACCEPTED | EXHAUSTED | ESCALATED
  dispatchAttemptCount Int     @default(0)
  dispatchAttempts     DispatchAttempt[]

  // Relations
  activityLogs ActivityLog[]
}

model Parcel {
  id             String        @id @default(uuid())
  jobId          String?
  job            Job?          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  quoteRequestId String?
  quoteRequest   QuoteRequest? @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  quoteId        String?
  quote          Quote?        @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  weightKg    Float
  lengthCm    Float
  widthCm     Float
  heightCm    Float
  quantity    Int     @default(1)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// PAYMENTS & SETTLEMENTS
// ==========================================

model PaymentTransaction {
  id          String @id @default(uuid())
  type        String // "charge" | "refund" | "payout"
  status      String // "PENDING" | "PROCESSING" | "COMPLETED" | "FAILED" | "REFUNDED"
  amount      Float
  currency    String @default("GBP")
  method      String // "stripe" | "paypal"
  description String

  // Optional References
  deliveryId      String?
  trackingNumber  String?
  jobNumber       String?
  customerName    String?
  customerEmail   String?
  customerId      String?
  businessId      String?
  stripePaymentId String?
  paypalOrderId   String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

model SettlementBatch {
  id            String   @id @default(uuid())
  recipientId   String
  recipientName String
  recipientType String // "driver" | "carrier"
  status        String // "DRAFT" | "PENDING_APPROVAL" | "APPROVED" | "PROCESSING" | "PAID" | "FAILED"
  periodStart   DateTime
  periodEnd     DateTime

  jobIds          String // Stored as JSON string array
  jobsCount       Int
  grossAmount     Float
  totalDeductions Float
  netAmount       Float

  method      String
  reference   String    @unique
  approvedBy  String?
  approvedAt  DateTime?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  // Stripe Connect payout tracking
  stripeTransferId String? // transfer_xxx from Stripe Connect
  stripePayoutId   String? // po_xxx if manual payout
  payoutStatus     String    @default("PENDING") // PENDING | PROCESSING | PAID | FAILED | RETRYING
  payoutError      String? // Error message if failed
  payoutAttempts   Int       @default(0)
  lastPayoutAt     DateTime?
}

model MediaAsset {
  id           String   @id @default(uuid())
  url          String
  filename     String
  size         String
  type         String // "image" | "icon" | "document"
  dateUploaded DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccountingEntry {
  id          String   @id @default(uuid())
  type        String // "credit" | "debit"
  category    String // "delivery_revenue" | "delivery_payment" | "driver_payout" ...
  amount      Float
  description String
  date        DateTime @default(now())
  reference   String // E.g., transaction.id or settlement.id
  balance     Float    @default(0)

  recipientId   String?
  recipientName String?
  settlementId  String?
  deliveryId    String?
}

// ==========================================
// COMMERCIAL CORE (PHASE A)
// ==========================================

model BusinessAccount {
  id              String  @id @default(uuid())
  tradingName     String
  companyName     String
  contactEmail    String
  contactPhone    String?
  billingAddress  String?
  billingCity     String?
  billingPostcode String?

  status          String  @default("ACTIVE") // "ACTIVE" | "ON_HOLD" | "PENDING" | "SUSPENDED"
  industryProfile String?
  
  // Registration & Tax
  registrationNumber String?
  vatNumber         String?
  directorName       String?
  logoUrl            String?

  totalSpend     Float   @default(0)
  currentBalance Float   @default(0)
  creditLimit    Float   @default(0)
  billingTerms   String? @default("Net 30")
  slaCompliance  Float   @default(100.0)
  totalJobs      Int     @default(0)

  contractId String?   @unique
  contract   Contract? @relation(fields: [contractId], references: [id])

  users    User[]
  jobs     Job[]
  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contract {
  id                String    @id @default(uuid())
  contractName      String
  contractRef       String    @unique
  clientId          String
  clientName        String
  startDate         DateTime
  endDate           DateTime?
  status            String    @default("ACTIVE") // "ACTIVE" | "EXPIRED" | "DRAFT"
  paymentTerms      String    @default("Net 30")
  monthlyVolumeTier String    @default("tier_1")

  baseRateDiscount  Float  @default(0.0)
  mileageRateFactor Float  @default(1.0)
  specialSlaParams  String @default("standard")

  // Relationships
  businessAccount BusinessAccount?
  rateRules       RateRule[]
  jobs            Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RateRule {
  id         String   @id @default(uuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  vehicleType   String
  baseRate      Float
  perMileRate   Float
  minimumCharge Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quote {
  id          String  @id @default(uuid())
  quoteNumber String  @unique
  customerId  String
  businessId  String?

  pickupPostcode         String
  pickupAddressLine1     String?
  pickupAddressLine2     String?
  pickupCity             String?
  pickupCounty           String?
  pickupLatitude         Float?
  pickupLongitude        Float?
  pickupFormattedAddress String?

  dropoffPostcode         String
  dropoffAddressLine1     String?
  dropoffAddressLine2     String?
  dropoffCity             String?
  dropoffCounty           String?
  dropoffLatitude         Float?
  dropoffLongitude        Float?
  dropoffFormattedAddress String?

  vehicleType String
  distanceKm  Float

  // Multi-Parcel Optimization Logs
  quantity     Int    @default(1)
  basePrice    Float?
  bulkDiscount Float  @default(0)

  estimatedCost Float
  status        String   @default("VALID") // "VALID" | "ACCEPTED" | "EXPIRED"
  expiresAt     DateTime

  parcels Parcel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// FLEET & CARRIERS (PHASE B)
// ==========================================

model CarrierProfile {
  id                    String   @id @default(uuid())
  companyName           String
  tradingName           String
  contactFirstName      String
  contactLastName       String
  email                 String
  phone                 String
  avatar                String?
  registrationNumber    String
  vatNumber             String?
  insuranceExpiry       DateTime
  operatorLicence       String
  operatorLicenceExpiry DateTime
  coverageRegions       String // Stored as JSON string array
  status                String   @default("PENDING") // "APPROVED" | "PENDING" | "SUSPENDED"

  totalJobsCompleted Int   @default(0)
  slaScore           Float @default(100.0)
  rating             Float @default(5.0)

  memberSince DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  users                 User[]
  vehicles              FleetVehicle[]
  complianceDocs        ComplianceDocument[]
  rates                 CarrierRate[]
  accountingIntegration AccountingIntegration?
}

model CarrierRate {
  id        String         @id @default(uuid())
  carrierId String
  carrier   CarrierProfile @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  vehicleType         String // "Small Van", "Medium Van", etc.
  baseRate            Float
  perKmRate           Float
  perStopRate         Float  @default(0)
  weekendSurcharge    Float  @default(0)
  outOfHoursSurcharge Float  @default(0)
  heavyGoodsSurcharge Float  @default(0)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  status        String    @default("ACTIVE") // "ACTIVE", "DRAFT", "EXPIRED"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrierId])
}

model FleetVehicle {
  id           String @id @default(uuid())
  registration String @unique
  type         String
  make         String
  model        String
  year         Int
  capacity     String
  status       String @default("ACTIVE") // "ACTIVE" | "MAINTENANCE" | "OFFLINE"

  motExpiry       DateTime
  insuranceExpiry DateTime
  lastService     DateTime

  carrierId String
  carrier   CarrierProfile @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  // Can be assigned to a specific driver (user)
  currentDriverId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComplianceDocument {
  id   String @id @default(uuid())
  type String // e.g. "operator_licence" | "goods_in_transit" | "public_liability"

  fileName String?
  fileUrl  String // Supabase Storage URL
  mimeType String?
  fileSize Int?

  status String @default("pending_review") // "verified" | "rejected" | "pending_review" | "expired"

  issueDate  DateTime?
  expiryDate DateTime?
  uploadDate DateTime  @default(now())

  rejectionReason String?
  adminNote       String?

  verifiedByAdminId String?
  verifiedByAdmin   User?     @relation("CarrierDocReview", fields: [verifiedByAdminId], references: [id], onDelete: SetNull)
  verifiedAt        DateTime?

  carrierId String
  carrier   CarrierProfile @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrierId])
  @@index([status])
}

// ==========================================
// INVOICING & ACTIVITY (PHASE D)
// ==========================================

model Invoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   @unique
  status          String   @default("PENDING") // "PAID" | "PENDING" | "OVERDUE" | "DRAFT"
  amount          Float
  currency        String   @default("GBP")
  date            DateTime @default(now())
  dueDate         DateTime
  description     String?
  autoInvoiceSent Boolean  @default(false)

  // Relations
  businessAccountId String?
  businessAccount   BusinessAccount? @relation(fields: [businessAccountId], references: [id])

  jobs Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id       String  @id @default(uuid())
  type     String // "delivery_created", "delivery_picked_up", "payment", "sla_warning", etc.
  title    String
  message  String
  severity String  @default("info") // "info" | "warning" | "urgent"
  read     Boolean @default(false)

  // Potential context
  userId     String?
  jobId      String?
  job        Job?    @relation(fields: [jobId], references: [id])
  deliveryId String?
  amount     Float?

  timestamp DateTime @default(now())
}

// ==========================================
// NOTIFICATIONS & SETTINGS (NEW)
// ==========================================

model NotificationSettings {
  id String @id @default(uuid())

  // Email (SMTP/Nodemailer)
  emailEnabled  Boolean @default(false)
  smtpHost      String?
  smtpPort      Int?
  smtpUser      String?
  smtpPass      String?
  emailFromName String?
  emailFromAddr String?

  // SMS (Twilio)
  smsEnabled  Boolean @default(false)
  twilioSid   String?
  twilioToken String?
  twilioFrom  String?

  // Notification Rules (Events)
  notifyOnJobCreated   Boolean @default(true)
  notifyOnJobAssigned  Boolean @default(true)
  notifyOnJobDelivered Boolean @default(true)
  notifyOnPayment      Boolean @default(true)

  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id        String  @id @default(uuid())
  type      String // "EMAIL" | "SMS"
  recipient String // email address or phone number
  subject   String? // for email
  message   String
  status    String // "SUCCESS" | "FAILED"
  error     String? // error details if failed

  // Optional relations
  jobId  String?
  userId String?

  createdAt DateTime @default(now())
}

// ==========================================
// HR & PAYROLL (EPIC 1)
// ==========================================

model HRRecord {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Compliance / Right to Work
  nationalInsurance String?
  taxCode           String? @default("1257L")
  bankAccountName   String?
  bankAccountNumber String?
  bankSortCode      String?

  // Employment Details
  employmentType String    @default("CONTRACTOR") // "EMPLOYEE" | "CONTRACTOR"
  startDate      DateTime  @default(now())
  endDate        DateTime?

  // Status
  backgroundCheckStatus String  @default("PENDING") // "PENDING" | "PASSED" | "FAILED"
  rightToWorkVerified   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimeOffRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String // "HOLIDAY" | "SICK" | "OTHER"
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    String   @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"

  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payslip {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  periodStart DateTime
  periodEnd   DateTime

  grossPay        Float
  taxDeductions   Float
  niDeductions    Float
  otherDeductions Float @default(0)
  netPay          Float

  status      String    @default("DRAFT") // "DRAFT" | "PUBLISHED" | "PAID"
  paymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// ACCOUNTING INTEGRATIONS (EPIC 4)
// ==========================================

model AccountingIntegration {
  id        String         @id @default(uuid())
  carrierId String         @unique
  carrier   CarrierProfile @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  provider     String // "XERO" | "FREEAGENT" | "SAGE"
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  tenantId     String? // Needed for Xero
  expiresAt    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// COMMERCIAL PRICING & PAYOUT ENGINE (PHASE E)
// ==========================================

model VehicleClass {
  id       String  @id @default(uuid())
  name     String  @unique // 'CAR', 'SMALL_VAN', 'MEDIUM_VAN', 'LARGE_VAN'
  isActive Boolean @default(true)

  maxWeightKg Float
  maxLengthCm Float
  maxWidthCm  Float
  maxHeightCm Float

  // Baseline Fallbacks (Overridden by specific PricingRules)
  baseFee           Float @default(0.0)
  mileageRate       Float @default(0.0)
  driverPickupFee   Float @default(0.0)
  driverMileageRate Float @default(0.0)

  pricingRules  PricingRule[]
  payoutRules   PayoutRule[]
  quoteRequests QuoteRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingRule {
  id             String       @id @default(uuid())
  name           String
  vehicleClassId String
  vehicle        VehicleClass @relation(fields: [vehicleClassId], references: [id])

  type         String // 'BASE_FEE', 'MILEAGE', 'WEIGHT_SURCHARGE', 'VOLUME_SURCHARGE', 'ACCESS_SURCHARGE', 'OOH_UPLIFT', 'EXTRA_STOP'
  conditionKey String? // 'weight_kg', 'stairs', 'out_of_hours'
  conditionMin Float?
  conditionMax Float?

  amount       Float
  isPercentage Boolean @default(false)

  createdAt DateTime @default(now())
}

model PayoutRule {
  id             String       @id @default(uuid())
  name           String
  vehicleClassId String
  vehicle        VehicleClass @relation(fields: [vehicleClassId], references: [id])

  type         String // 'PICKUP_FEE', 'MILEAGE', 'WEIGHT_BONUS', 'ACCESS_BONUS', 'EXTRA_STOP'
  conditionKey String?
  conditionMin Float?
  conditionMax Float?

  amount       Float
  isPercentage Boolean @default(false)

  createdAt DateTime @default(now())
}

model QuoteRequest {
  id              String @id @default(uuid())
  pickupPostcode  String
  pickupAddressLine1 String?
  pickupAddressLine2 String?
  pickupCity         String?
  pickupCounty       String?
  pickupLatitude     Float?
  pickupLongitude    Float?
  pickupFormattedAddress String?

  dropoffPostcode String
  dropoffAddressLine1 String?
  dropoffAddressLine2 String?
  dropoffCity         String?
  dropoffCounty       String?
  dropoffLatitude     Float?
  dropoffLongitude    Float?
  dropoffFormattedAddress String?

  distanceMiles   Float

  // Imputed Metrics
  actualWeightKg     Float
  volumetricWeightKg Float
  chargeableWeightKg Float

  // Selected vs Recommended
  recommendedVehicleId String
  vehicle              VehicleClass @relation(fields: [recommendedVehicleId], references: [id])

  customerTotal     Float
  driverPayoutTotal Float
  marginPercentage  Float

  status String @default("AUTO_APPROVED") // 'AUTO_APPROVED', 'PENDING_REVIEW', 'REJECTED'

  customerId String?
  customer   User?   @relation(fields: [customerId], references: [id])

  lineItems QuoteLineItem[]
  parcels   Parcel[]
  job       Job?

  createdAt DateTime @default(now())
}

model QuoteLineItem {
  id             String       @id @default(uuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  target      String // 'CUSTOMER' or 'DRIVER'
  type        String // 'BASE_FEE', 'WEIGHT_SURCHARGE', 'MILEAGE'
  amount      Float
  description String

  createdAt DateTime @default(now())
}

model ManualReviewCase {
  id             String @id @default(uuid())
  quoteRequestId String @unique
  reason         String // 'MARGIN_TOO_LOW', 'OVERWEIGHT', 'OVERSIZE'
  status         String @default("OPEN") // 'OPEN', 'RESOLVED', 'REJECTED'

  reviewedBy String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
}

// ==========================================
// CMS & CONFIGURATION
// ==========================================

model PageContent {
  id              String  @id @default(uuid())
  slug            String  @unique
  title           String
  metaDescription String?
  bodyContent     Json // Flexible JSON structure for page sections
  published       Boolean @default(true)

  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model GlobalConfig {
  id     String @id @default(uuid())
  key    String @unique // e.g. "homepage", "header", "footer"
  config Json

  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model CMSRevision {
  id        String   @id @default(uuid())
  entityType String  // "GLOBAL_CONFIG" | "PAGE_CONTENT"
  entityKey  String  // e.g., "global_cms_bundle" or a page slug like "home"
  snapshot  Json
  
  updatedBy String?
  createdAt DateTime @default(now())
  
  @@index([entityType, entityKey])
}

model JobCounter {
  id      Int @id @default(1)
  current Int @default(0)
}

// ==========================================
// STRIPE MARKETPLACE TAX LEDGERS
// ==========================================

// Explicit per-job Tax & NI ledger for UK compliance
model TaxNiRecord {
  id     String @id @default(uuid())
  userId String
  jobId  String

  employmentType String // "EMPLOYEE" | "CONTRACTOR"
  grossPay       Float
  taxAmount      Float
  niAmount       Float
  netPay         Float

  taxCode    String @default("1257L")
  niCategory String @default("A") // Standard rate NI

  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([jobId])
}

// Explicit per-job VAT ledger for HMRC compliance
model VatRecord {
  id    String @id @default(uuid())
  jobId String

  customerAmount Float // Full amount customer paid (ex VAT)
  vatRate        Float  @default(20.0)
  vatAmount      Float // Calculated VAT
  vatRegNumber   String @default("GB 384 9210 55")

  reconciled   Boolean   @default(false)
  reconciledAt DateTime?
  reconciledBy String?

  createdAt DateTime @default(now())

  @@index([jobId])
}

// Per-job financial breakdown for admin reporting
model JobFinancialRecord {
  id    String @id @default(uuid())
  jobId String @unique

  jobNumber      String
  customerAmount Float // Full price paid by customer (inc VAT)
  driverPayout   Float  @default(0)
  carrierPayout  Float  @default(0)
  vatAmount      Float
  marginAmount   Float

  stripePaymentIntentId   String?
  stripeDriverTransferId  String?
  stripeCarrierTransferId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
}

// ==========================================
// DISPUTES & REFUNDS (SECTION C)
// ==========================================

model Dispute {
  id    String @id @default(uuid())
  jobId String
  job   Job    @relation("DisputeJob", fields: [jobId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User   @relation("DisputeCreator", fields: [creatorId], references: [id])

  targetId String?
  target   User?   @relation("DisputeTarget", fields: [targetId], references: [id])

  reason      String
  description String @db.Text
  status      String @default("OPEN") // "OPEN" | "REVIEWING" | "RESOLVED" | "REJECTED"

  refundStatus String? // "FULL" | "PARTIAL" | "NONE"
  refundAmount Float?

  messages DisputeMessage[]

  resolvedBy String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([creatorId])
  @@index([status])
}

model DisputeMessage {
  id        String  @id @default(uuid())
  disputeId String
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("MessageAuthor", fields: [authorId], references: [id])

  content String  @db.Text
  fileUrl String? // Optional evidence

  createdAt DateTime @default(now())
}

// ==========================================
// AUTOMATED DISPATCH ENGINE (PHASE DISPATCH)
// ==========================================

// Records each individual offer sent to a driver during automated dispatch.
// One DispatchAttempt per driver per job; status tracks the response lifecycle.
model DispatchAttempt {
  id     String @id @default(uuid())
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  driverId String
  driver   User   @relation("DriverOffers", fields: [driverId], references: [id], onDelete: Cascade)

  // PENDING | ACCEPTED | REJECTED | EXPIRED | CANCELLED
  status String @default("PENDING")

  offerSentAt    DateTime  @default(now())
  offerExpiresAt DateTime
  respondedAt    DateTime?

  attemptNumber Int    @default(1)
  distanceKm    Float? // Distance from driver to pickup at time of offer

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([driverId])
  @@index([status])
  @@index([offerExpiresAt])
}
