# Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# ⚠ NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────
#
# KEY ROTATION CHECKLIST (run after any suspected key exposure):
#   1. JWT_SECRET                — generate: openssl rand -base64 48
#   2. STRIPE_SECRET_KEY         — https://dashboard.stripe.com/apikeys
#   3. STRIPE_WEBHOOK_SECRET     — https://dashboard.stripe.com/webhooks
#   4. GOOGLE_MAPS_API_KEY       — https://console.cloud.google.com/apis/credentials
#   5. SUPABASE_SERVICE_ROLE_KEY — https://supabase.com/dashboard → Settings → API
#   6. CLOUDINARY keys           — https://console.cloudinary.com/settings/api-keys
# ─────────────────────────────────────────────────────────────────────────────

# --- Database (Supabase PostgreSQL) ---
# Get from: Supabase Dashboard → Settings → Database → Connection String
# DATABASE_URL — use the "Transaction" pooler (port 6543) for runtime queries
# DIRECT_URL   — use the "Session" direct connection (port 5432) for prisma migrate
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# --- Supabase (Realtime + Admin Operations) ---
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME_service_role_key_from_supabase_settings_api"

# --- Authentication ---
# REQUIRED: Must be a strong, random secret. App will refuse to start without this.
# Generate a new value with: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_48"

# --- CORS ---
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:3000,https://your-vercel-deployment.vercel.app"

# --- Stripe ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="CHANGE_ME_sk_live_or_sk_test_from_stripe_dashboard"
# Get from https://dashboard.stripe.com/webhooks (after adding your Vercel endpoint URL)
STRIPE_WEBHOOK_SECRET="CHANGE_ME_whsec_from_stripe_webhooks_dashboard"

# --- Google Maps ---
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY="CHANGE_ME_AIzaSy_from_google_cloud_console"

# --- Cloudinary (Media Uploads) ---
CLOUDINARY_CLOUD_NAME="CHANGE_ME_your_cloud_name"
CLOUDINARY_API_KEY="CHANGE_ME_your_api_key"
CLOUDINARY_API_SECRET="CHANGE_ME_your_api_secret"

# --- OpenRouter AI (LLM Intelligence) ---
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY="CHANGE_ME_sk_or_v1_from_openrouter"
OPENROUTER_MODEL="google/gemini-2.0-flash-001"

# --- Server (for local dev only — Vercel manages PORT automatically) ---
PORT=3000
NODE_ENV=development
